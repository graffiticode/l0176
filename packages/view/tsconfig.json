{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "useDefineForClassFields": true,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": ["src", "embed"]
}
