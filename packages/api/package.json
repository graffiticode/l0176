{
  "name": "@graffiticode/api-l0176",
  "private": true,
  "version": "0.1.0",
  "description": "L0176 language server — runs the L0176 core and serves /compile, /form, and public static assets",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "FIRESTORE_EMULATOR_HOST=\"127.0.0.1:8080\" AUTH_URL=\"http://127.0.0.1:4100\" tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@graffiticode/auth": "^2.1.2",
    "@graffiticode/l0176": "*",
    "@graffiticode/tracing": "^0.3.1",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.1",
    "express": "^4.21.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/errorhandler": "^1.5.3",
    "@types/express": "^4.17.21",
    "@types/method-override": "^0.0.35",
    "@types/morgan": "^1.9.9",
    "supertest": "^7.0.0"
  }
}
